# pnpm dev 使用 --mode dev，因此 Vite 会加载 config/.env 和 config/.env.dev。
# 当前业务环境标识。Vite 选择 env 文件看的是 --mode，不需要在这里配置 NODE_ENV。
VITE_APP_ENV=dev

# 应用名称，也会作为当前构建输出目录名的一部分。
VITE_APP_NAME=ytora
VITE_HELLO=hello ytora

# 本地开发服务器配置。
VITE_APP_HOST=0.0.0.0
VITE_APP_PORT=8765
VITE_OPEN=true

# 后端请求相关配置。
VITE_REQUEST_BASE_URL=/ytora/
VITE_FILE_UPLOAD_PATH=sys/file/upload
VITE_FILE_DOWNLOAD_PATH=sys/file/download
VITE_REQUEST_TIME_OUT=1000000

# token 过期时间，单位：秒。
VITE_TOKEN_TIME_OUT=6000

# 公共资源路径。部署到域名根路径时使用 /。
VITE_PUBLIC_PATH=/
