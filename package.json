{
  "name": "ytora-vue3",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts --mode dev",
    "build:test": "pnpm lint && vue-tsc --noEmit && vite build --config config/vite.config.ts --mode test",
    "build:prod": "pnpm lint && vue-tsc --noEmit && vite build --config config/vite.config.ts --mode prod",
    "preview:test": "vite preview --config config/vite.config.ts --mode test",
    "preview:prod": "vite preview --config config/vite.config.ts --mode prod",
    "lint": "eslint src config --config config/eslint.config.mjs --max-warnings 0",
    "lint:fix": "eslint src config --config config/eslint.config.mjs --fix",
    "format": "prettier --write . --config config/prettier.config.mjs && pnpm lint:fix",
    "format:check": "prettier --check . --config config/prettier.config.mjs && pnpm lint"
  },
  "scripts-desc": {
    "dev": "启动本地开发服务，--config 参数表示指定 Vite 配置文件，--mode dev 表示指定环境配置文件：.env & .env.dev",
    "build:test": "构建测试环境包，pnpm lint：检查代码规范；vue-tsc --noEmit：进行 TypeScript 类型检查，但是不输出编译文件；vite build表示使用vite构建包；&& 表示：前一步成功，才会执行下一步",
    "build:prod": "构建生产环境包",
    "preview:test": "预览测试环境构建结果，vite preview 用来预览打包后的产物",
    "preview:prod": "预览生产环境构建结果",
    "lint": "检查代码规范，只检查src、config两个文件夹下的代码，--config config/eslint.config.mjs 指定 ESLint 配置文件，--max-warnings 0 表示不允许有 warning",
    "lint:fix": "在lint的基础上，可以自动修复一些简单的问题，比如：格式、排序、简单语法风格",
    "format": "格式化整个项目，然后再用 ESLint 自动修复代码问题",
    "format:check": "检查代码格式和规范，但不修改文件"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.42.1",
    "@tanstack/vue-query": "^5.99.0",
    "@unocss/reset": "^66.6.8",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.15.0",
    "codemirror": "^6.0.2",
    "echarts": "^6.0.0",
    "install": "^0.13.0",
    "naive-ui": "^2.44.1",
    "npm": "^11.14.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4",
    "vxe-table": "^4.18.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@iconify-json/lucide": "^1.2.102",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.4.2",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.26.0"
}
